{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "containerapps_lms_app_name": {
            "defaultValue": "lms-app",
            "type": "String"
        },
        "containerapps_lms_main_app_name": {
            "defaultValue": "lms-main-app",
            "type": "String"
        },
        "containerapps_lms_landing_app_name": {
            "defaultValue": "lms-landing-app",
            "type": "String"
        },
        "flexibleServers_lms_name": {
            "defaultValue": "lms",
            "type": "String"
        },
        "registries_lmsrepository_name": {
            "defaultValue": "lmsrepository",
            "type": "String"
        },
        "flexibleServers_learnmanagement_name": {
            "defaultValue": "learnmanagement",
            "type": "String"
        },
        "_artifactsLocation": {
            "type": "string",
            "defaultValue": "https://raw.githubusercontent.com/Kuvance/lms-arm-files/main/",
            "metadata": {
                "description": "Base URI where templates are stored."
            }
        },
        "administratorLoginPassword": {
            "type": "secureString"
        },
        "managedEnvironment_name": {
            "type": "String",
            "defaultValue": "lms-managed-environment"
        },
        "containerRegistryPassword": {
            "type": "secureString",
            "metadata": {
                "description": "Password for the Azure Container Registry."
            }
        },
        "serverNameSuffix": {
            "type": "String",
            "defaultValue": "",
            "metadata": {
                "description": "Optional suffix to make server names globally unique."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2021-04-01",
            "name": "coreInfraDeployment",
            "dependsOn": [],
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "[uri(parameters('_artifactsLocation'), 'core-infra.json')]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "registries_lmsrepository_name": {
                        "value": "[parameters('registries_lmsrepository_name')]"
                    }
                }
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2021-04-01",
            "name": "databaseDeployment",
            "dependsOn": [
                "[resourceId('Microsoft.Resources/deployments', 'coreInfraDeployment')]"
            ],
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "[uri(parameters('_artifactsLocation'), 'database.json')]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "flexibleServers_lms_name": {
                        "value": "[parameters('flexibleServers_lms_name')]"
                    },
                    "flexibleServers_learnmanagement_name": {
                        "value": "[parameters('flexibleServers_learnmanagement_name')]"
                    },
                    "administratorLoginPassword": {
                        "value": "[parameters('administratorLoginPassword')]"
                    },
                    "serverNameSuffix": {
                        "value": "[parameters('serverNameSuffix')]"
                    }
                }
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2021-04-01",
            "name": "containerAppsDeployment",
            "dependsOn": [
                "[resourceId('Microsoft.Resources/deployments', 'databaseDeployment')]"
            ],
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "[uri(parameters('_artifactsLocation'), 'container-apps.json')]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "containerapps_lms_app_name": {
                        "value": "[parameters('containerapps_lms_app_name')]"
                    },
                    "containerapps_lms_main_app_name": {
                        "value": "[parameters('containerapps_lms_main_app_name')]"
                    },
                    "containerapps_lms_landing_app_name": {
                        "value": "[parameters('containerapps_lms_landing_app_name')]"
                    },
                    "registries_lmsrepository_name": {
                        "value": "[parameters('registries_lmsrepository_name')]"
                    },
                    "managedEnvironment_name": {
                        "value": "[parameters('managedEnvironment_name')]"
                    },
                    "containerRegistryPassword": {
                        "value": "[parameters('containerRegistryPassword')]"
                    }
                }
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2021-04-01",
            "name": "optionalSupportDeployment",
            "dependsOn": [
                "[resourceId('Microsoft.Resources/deployments', 'coreInfraDeployment')]"
            ],
            "properties": {
                "mode": "Incremental",
                "templateLink": {
                    "uri": "[uri(parameters('_artifactsLocation'), 'optional-support.json')]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "registries_lmsrepository_name": {
                        "value": "[parameters('registries_lmsrepository_name')]"
                    }
                }
            }
        }
    ]
}