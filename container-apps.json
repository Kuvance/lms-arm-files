{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "containerapps_lms_app_name": {
            "defaultValue": "lms-app",
            "type": "String"
        },
        "containerapps_lms_main_app_name": {
            "defaultValue": "lms-main-app",
            "type": "String"
        },
        "containerapps_lms_landing_app_name": {
            "defaultValue": "lms-landing-app",
            "type": "String"
        },
        "registries_lmsrepository_name": {
            "type": "String",
            "defaultValue": "lmsrepository"
        },
        "managedEnvironment_name": {
            "type": "String",
            "defaultValue": "lms-managed-environment"
        },
        "containerRegistryPassword": {
            "type": "secureString",
            "metadata": {
                "description": "Legacy parameter. Now automated via listCredentials."
            }
        }
    },
    "variables": {},
    "resources": [
        {
            "type": "Microsoft.App/managedEnvironments",
            "apiVersion": "2024-03-01",
            "name": "[parameters('managedEnvironment_name')]",
            "location": "West US 2",
            "properties": {
                "zoneRedundant": false,
                "kedaConfiguration": {},
                "daprConfiguration": {},
                "workloadProfiles": [
                    {
                        "workloadProfileType": "Consumption",
                        "name": "Consumption"
                    }
                ]
            }
        },
        {
            "type": "Microsoft.App/containerapps",
            "apiVersion": "2025-10-02-preview",
            "name": "[parameters('containerapps_lms_app_name')]",
            "location": "West US 2",
            "kind": "containerapps",
            "identity": {
                "type": "None"
            },
            "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]",
                "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]",
                "workloadProfileName": "Consumption",
                "configuration": {
                    "secrets": [
                        {
                            "name": "reg-pswd-acr",
                            "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('registries_lmsrepository_name')), '2023-07-01').passwords[0].value]"
                        }
                    ],
                    "activeRevisionsMode": "Single",
                    "ingress": {
                        "external": true,
                        "targetPort": 8000,
                        "exposedPort": 0,
                        "transport": "Auto",
                        "traffic": [
                            {
                                "weight": 100,
                                "latestRevision": true
                            }
                        ],
                        "allowInsecure": false,
                        "clientCertificateMode": "Ignore",
                        "stickySessions": {
                            "affinity": "none"
                        }
                    },
                    "registries": [
                        {
                            "server": "[concat(parameters('registries_lmsrepository_name'), '.azurecr.io')]",
                            "username": "[parameters('registries_lmsrepository_name')]",
                            "passwordSecretRef": "reg-pswd-acr"
                        }
                    ],
                    "identitySettings": [],
                    "maxInactiveRevisions": 100
                },
                "template": {
                    "containers": [
                        {
                            "image": "[concat(parameters('registries_lmsrepository_name'), '.azurecr.io/coursebackend:latest')]",
                            "imageType": "ContainerImage",
                            "name": "[parameters('containerapps_lms_app_name')]",
                            "resources": {
                                "cpu": 0.5,
                                "memory": "1Gi"
                            }
                        }
                    ],
                    "scale": {
                        "minReplicas": 0,
                        "maxReplicas": 10,
                        "cooldownPeriod": 300,
                        "pollingInterval": 30
                    }
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]"
            ]
        },
        {
            "type": "Microsoft.App/containerapps",
            "apiVersion": "2025-10-02-preview",
            "name": "[parameters('containerapps_lms_landing_app_name')]",
            "location": "West US 2",
            "kind": "containerapps",
            "identity": {
                "type": "None"
            },
            "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]",
                "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]",
                "workloadProfileName": "Consumption",
                "configuration": {
                    "secrets": [
                        {
                            "name": "reg-pswd-acr",
                            "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('registries_lmsrepository_name')), '2023-07-01').passwords[0].value]"
                        }
                    ],
                    "activeRevisionsMode": "Single",
                    "ingress": {
                        "external": true,
                        "targetPort": 3000,
                        "exposedPort": 0,
                        "transport": "Auto",
                        "traffic": [
                            {
                                "weight": 100,
                                "latestRevision": true
                            }
                        ],
                        "allowInsecure": false,
                        "stickySessions": {
                            "affinity": "none"
                        }
                    },
                    "registries": [
                        {
                            "server": "[concat(parameters('registries_lmsrepository_name'), '.azurecr.io')]",
                            "username": "[parameters('registries_lmsrepository_name')]",
                            "passwordSecretRef": "reg-pswd-acr"
                        }
                    ],
                    "identitySettings": [],
                    "maxInactiveRevisions": 100
                },
                "template": {
                    "containers": [
                        {
                            "image": "[concat(parameters('registries_lmsrepository_name'), '.azurecr.io/lms-landing-page:latest')]",
                            "imageType": "ContainerImage",
                            "name": "[parameters('containerapps_lms_landing_app_name')]",
                            "resources": {
                                "cpu": 0.5,
                                "memory": "1Gi"
                            }
                        }
                    ],
                    "scale": {
                        "minReplicas": 0,
                        "maxReplicas": 10,
                        "cooldownPeriod": 300,
                        "pollingInterval": 30
                    }
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]"
            ]
        },
        {
            "type": "Microsoft.App/containerapps",
            "apiVersion": "2025-10-02-preview",
            "name": "[parameters('containerapps_lms_main_app_name')]",
            "location": "West US 2",
            "kind": "containerapps",
            "identity": {
                "type": "None"
            },
            "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]",
                "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]",
                "workloadProfileName": "Consumption",
                "configuration": {
                    "secrets": [
                        {
                            "name": "reg-pswd-acr",
                            "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', parameters('registries_lmsrepository_name')), '2023-07-01').passwords[0].value]"
                        }
                    ],
                    "activeRevisionsMode": "Single",
                    "ingress": {
                        "external": true,
                        "targetPort": 3002,
                        "exposedPort": 0,
                        "transport": "Auto",
                        "traffic": [
                            {
                                "weight": 100,
                                "latestRevision": true
                            }
                        ],
                        "allowInsecure": false,
                        "clientCertificateMode": "Accept",
                        "stickySessions": {
                            "affinity": "none"
                        }
                    },
                    "registries": [
                        {
                            "server": "[concat(parameters('registries_lmsrepository_name'), '.azurecr.io')]",
                            "username": "[parameters('registries_lmsrepository_name')]",
                            "passwordSecretRef": "reg-pswd-acr"
                        }
                    ],
                    "identitySettings": [],
                    "maxInactiveRevisions": 100
                },
                "template": {
                    "containers": [
                        {
                            "image": "[concat(parameters('registries_lmsrepository_name'), '.azurecr.io/lms-main-page:latest')]",
                            "imageType": "ContainerImage",
                            "name": "[parameters('containerapps_lms_main_app_name')]",
                            "resources": {
                                "cpu": 0.5,
                                "memory": "1Gi"
                            }
                        }
                    ],
                    "scale": {
                        "minReplicas": 0,
                        "maxReplicas": 10,
                        "cooldownPeriod": 300,
                        "pollingInterval": 30
                    }
                }
            },
            "dependsOn": [
                "[resourceId('Microsoft.App/managedEnvironments', parameters('managedEnvironment_name'))]"
            ]
        }
    ]
}