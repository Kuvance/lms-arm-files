{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "flexibleServers_lms_name": {
            "defaultValue": "lmsdbcore",
            "type": "String"
        },
        "flexibleServers_learnmanagement_name": {
            "defaultValue": "lmsdbade",
            "type": "String"
        },
        "administratorLoginPassword": {
            "type": "secureString"
        },
        "serverNameSuffix": {
            "type": "String",
            "defaultValue": "20260409"
        }
    },
    "resources": [
        {
            "type": "Microsoft.DBforPostgreSQL/flexibleServers",
            "apiVersion": "2025-08-01",
            "name": "[concat(parameters('flexibleServers_learnmanagement_name'), parameters('serverNameSuffix'))]",
            "location": "West US 2",
            "sku": {
                "name": "Standard_B1ms",
                "tier": "Burstable"
            },
            "properties": {
                "administratorLogin": "lmsadmin",
                "administratorLoginPassword": "[parameters('administratorLoginPassword')]",
                "version": "17",
                "storage": {
                    "storageSizeGB": 32
                },
                "network": {
                    "publicNetworkAccess": "Enabled"
                },
                "authConfig": {
                    "activeDirectoryAuth": "Disabled",
                    "passwordAuth": "Enabled"
                }
            }
        },
        {
            "type": "Microsoft.DBforPostgreSQL/flexibleServers",
            "apiVersion": "2025-08-01",
            "name": "[concat(parameters('flexibleServers_lms_name'), parameters('serverNameSuffix'))]",
            "location": "West US 2",
            "sku": {
                "name": "Standard_B1ms",
                "tier": "Burstable"
            },
            "properties": {
                "administratorLogin": "lmsadmin",
                "administratorLoginPassword": "[parameters('administratorLoginPassword')]",
                "version": "17",
                "storage": {
                    "storageSizeGB": 128
                },
                "network": {
                    "publicNetworkAccess": "Enabled"
                },
                "authConfig": {
                    "activeDirectoryAuth": "Disabled",
                    "passwordAuth": "Enabled"
                }
            }
        }
    ]
}